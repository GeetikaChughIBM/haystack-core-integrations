# DB2 Database Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to git!

# Local DB2 Connection (3-parameter method)
DB2_USER=your_username
DB2_PASSWORD=your_password
DB2_DATABASE=TESTDB

# Optional: Specify host and port (defaults: localhost, 50000)
# DB2_HOST=localhost
# DB2_PORT=50000

# Remote DB2 Connection (full connection string)
# DB2_CONNECTION_STRING=DATABASE=BLUDB;HOSTNAME=your-host.ibmappdomain.cloud;PORT=32310;PROTOCOL=TCPIP;UID=your_username;PWD=your_password;SECURITY=SSL;

# Remote DB2 Connection (individual parameters)
# DB2_HOSTNAME=your-host.ibmappdomain.cloud
# DB2_PORT=32310
# DB2_DATABASE=BLUDB
# DB2_USER=your_username
# DB2_PASSWORD=your_password

# Optional: Test Configuration
# DB2_TEST_TABLE=test_documents
# DB2_EMBEDDING_DIMENSION=384