# DB2 environment configuration
# Copy this file to .env and fill in your actual credentials.
# Never commit populated credentials.

# Required connection settings for the parameter-based connection flow
DB2_DATABASE=TESTDB
DB2_HOSTNAME=your-db2-host.example.com
DB2_PORT=50000
DB2_SSL_PORT=50001
DB2_SSL_ENABLED=false
DB2_USER=your_username
DB2_PASSWORD=your_password

# Optional: provide a full DB2 connection string instead of individual fields.
# This is useful when your environment already gives you a complete DSN.
# DB2_CONNECTION_STRING=DATABASE=TESTDB;HOSTNAME=your-db2-host.example.com;PORT=50000;PROTOCOL=TCPIP;UID=your_username;PWD=your_password;

# Optional: SSL certificate path for TLS connections.
# When DB2_SSL_ENABLED=true, prefer DB2_SSL_PORT=50001.
# DB2_SSL_CERTIFICATE=/absolute/path/to/db2server.crt
# DB2_SSL_CERT_PATH=/absolute/path/to/db2server.crt

# Optional: test/example overrides
# DB2_TEST_TABLE=haystack_documents
# DB2_EMBEDDING_DIMENSION=384